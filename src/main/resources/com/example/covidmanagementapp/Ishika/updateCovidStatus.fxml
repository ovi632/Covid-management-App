      <Label fx:id="errorLabel" layoutX="356.0" layoutY="20.0" prefHeight="93.0" prefWidth="186.0" />
      <ComboBox fx:id="covidStatusCB" layoutX="133.0" layoutY="101.0" prefWidth="150.0" />
      <Label layoutX="51.0" layoutY="105.0" text="Covid Status:" />
      <TextField fx:id="operatorNotesTF" layoutX="46.0" layoutY="157.0" promptText="Operator Notes" />
      <Button layoutX="223.0" layoutY="156.0" mnemonicParsing="false" onAction="#updateButtonOA" prefHeight="26.0" prefWidth="82.0" text="Update" />
      <Label fx:id="notificationLabel" layoutX="45.0" layoutY="230.0" prefHeight="126.0" prefWidth="437.0" />
      <Button layoutX="462.0" layoutY="388.0" mnemonicParsing="false" onAction="#backButtonOA" prefHeight="26.0" prefWidth="82.0" text="Back" />
