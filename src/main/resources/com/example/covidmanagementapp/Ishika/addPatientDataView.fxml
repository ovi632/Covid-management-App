<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="434.0" prefWidth="541.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.covidmanagementapp.Ishika.AddPatientDataViewController">
   <children>
      <TextField fx:id="patientNameTF" layoutX="81.0" layoutY="33.0" promptText="Patient Name" />
      <TextField fx:id="ageTF" layoutX="81.0" layoutY="76.0" promptText="Age" />
      <RadioButton fx:id="maleRadioButton" layoutX="156.0" layoutY="122.0" mnemonicParsing="false" text="Male" />
      <RadioButton fx:id="femaleRadioButton" layoutX="238.0" layoutY="122.0" mnemonicParsing="false" text="Female" />
      <Label layoutX="81.0" layoutY="122.0" text="Gender:" />
      <TextField fx:id="phoneNumberTF" layoutX="310.0" layoutY="33.0" promptText="Phone Number" />
      <TextField fx:id="addressTF" layoutX="310.0" layoutY="81.0" promptText="Address" />
      <Button layoutX="192.0" layoutY="168.0" mnemonicParsing="false" onAction="#saveButtonOA" prefHeight="26.0" prefWidth="150.0" text="Save" />
      <Label fx:id="notificationLabel" layoutX="80.0" layoutY="217.0" prefHeight="128.0" prefWidth="411.0" />
      <Button layoutX="384.0" layoutY="381.0" mnemonicParsing="false" onAction="#backbuttonOA" prefHeight="26.0" prefWidth="150.0" text="Back" />
   </children>
</AnchorPane>
