<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.covidmanagementapp.Ashraf.VaccinationHistoryAndCertificateViewController">
   <children>
      <Label layoutX="30.0" layoutY="21.0" text="Vaccination ID" />
      <TextField fx:id="vaccinationIdTF" layoutX="140.0" layoutY="17.0" />
      <Label fx:id="errorLabel" layoutX="363.0" layoutY="12.0" prefHeight="39.0" prefWidth="221.0" />
      <Button layoutX="30.0" layoutY="77.0" mnemonicParsing="false" onAction="#searchRecordButtonOA" prefHeight="26.0" prefWidth="111.0" text="Search Record" />
      <Button layoutX="220.0" layoutY="77.0" mnemonicParsing="false" onAction="#checkCertificateStatusButtonOA" prefHeight="26.0" prefWidth="160.0" text="Check Certificate Status" />
      <Label fx:id="certificateStatusLabel" layoutX="408.0" layoutY="71.0" prefHeight="39.0" prefWidth="192.0" />
      <TableView fx:id="vaccinationHistoryAndCertificateTV" layoutX="30.0" layoutY="136.0" prefHeight="200.0" prefWidth="532.0">
        <columns>
          <TableColumn fx:id="vaccineNameTC" prefWidth="124.0" text="Vaccine Name" />
          <TableColumn fx:id="doseNumberTC" prefWidth="93.0" text="Dose Number" />
            <TableColumn fx:id="vaccinationDateTC" prefWidth="105.0" text="Vaccination Date" />
            <TableColumn fx:id="vaccinationCenterTC" prefWidth="116.0" text="Vaccination Center" />
            <TableColumn fx:id="staffIDTC" prefWidth="93.0" text="Staff ID" />
        </columns>
      </TableView>
      <Button layoutX="220.0" layoutY="360.0" mnemonicParsing="false" onAction="#backToDashboardButtonOA" prefHeight="26.0" prefWidth="160.0" text="Back to Dashboard" />
   </children>
</AnchorPane>
