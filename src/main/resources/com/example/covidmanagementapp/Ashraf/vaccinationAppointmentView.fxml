<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.covidmanagementapp.Ashraf.VaccinationAppointmentViewController">
   <children>
      <ComboBox fx:id="vaccineTypeCB" layoutX="112.0" layoutY="20.0" prefWidth="150.0" />
      <Label layoutX="15.0" layoutY="26.0" text="Vaccine Type" />
      <ComboBox fx:id="doseNumberCB" layoutX="112.0" layoutY="62.0" prefWidth="150.0" />
      <Label layoutX="14.0" layoutY="67.0" text="Dose Number" />
      <ComboBox fx:id="vaccinationCenterCB" layoutX="436.0" layoutY="63.0" prefWidth="150.0" />
      <Label layoutX="315.0" layoutY="67.0" text="Vaccination Center" />
      <Label layoutX="283.0" layoutY="25.0" text="Preferred Vaccination Date" />
      <DatePicker fx:id="preferredVaccinationDatePicker" layoutX="436.0" layoutY="22.0" prefHeight="26.0" prefWidth="150.0" />
      <Button layoutX="123.0" layoutY="118.0" mnemonicParsing="false" onAction="#checkEligibilityButtonOA" text="Check Eligibility" />
      <Button layoutX="354.0" layoutY="118.0" mnemonicParsing="false" onAction="#submitAppointmentButtonOA" text="Submit Appointment" />
      <Button layoutX="240.0" layoutY="354.0" mnemonicParsing="false" onAction="#backToDashboardButtonOA" text="Back to Dashboard" />
   </children>
</AnchorPane>
