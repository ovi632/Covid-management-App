<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="589.0" prefWidth="623.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.covidmanagementapp.Ashraf.doctorCheckPatientInfoViewController">
   <children>
      <TableView fx:id="patientInfoTableView" layoutX="14.0" layoutY="173.0" prefHeight="200.0" prefWidth="598.0">
        <columns>
          <TableColumn fx:id="nameInPatientInfoTC" prefWidth="164.0" text="Name" />
          <TableColumn fx:id="ageInPatientInfoTC" prefWidth="65.0" text="Age" />
            <TableColumn fx:id="genderInPatientInfoTC" prefWidth="127.0" text="Gender" />
            <TableColumn fx:id="previousDiagnosesInPatientInfoTC" prefWidth="241.0" text="Previous Diagnoses" />
        </columns>
      </TableView>
      <Button layoutX="215.0" layoutY="549.0" mnemonicParsing="false" onAction="#backToDashboardButtonOA" prefHeight="26.0" prefWidth="194.0" text="Back to Dashboard" />
      <TextField fx:id="registrationIdTF" layoutX="27.0" layoutY="22.0" prefHeight="37.0" prefWidth="183.0" promptText="Registration ID" />
      <Label fx:id="notificationLabel" layoutX="15.0" layoutY="59.0" prefHeight="37.0" prefWidth="226.0" />
      <Button layoutX="55.0" layoutY="96.0" mnemonicParsing="false" onAction="#SearchButtonOA" prefHeight="25.0" prefWidth="127.0" text="Search" />
      <Label fx:id="infoShowLabel" layoutX="325.0" layoutY="14.0" prefHeight="97.0" prefWidth="287.0" />
