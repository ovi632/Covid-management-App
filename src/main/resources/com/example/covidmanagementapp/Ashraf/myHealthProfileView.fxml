<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.covidmanagementapp.Ashraf.MyHealthProfileViewController">
   <children>
      <TableView fx:id="myHealthProfileTV" layoutX="14.0" layoutY="57.0" prefHeight="200.0" prefWidth="571.0">
        <columns>
          <TableColumn fx:id="nameTC" prefWidth="75.0" text="Name" />
          <TableColumn fx:id="ageTC" prefWidth="75.0" text="Age" />
            <TableColumn fx:id="genderTC" prefWidth="75.0" text="Gender" />
            <TableColumn fx:id="covidStatusTC" prefWidth="94.0" text="Covid Status" />
            <TableColumn fx:id="lastStatusUpdateDateTC" prefWidth="150.0" text="Last Status Update Date" />
            <TableColumn fx:id="DiagnosisTC" prefWidth="101.0" text="Diagnosis" />
        </columns>
      </TableView>
      <Button layoutX="240.0" layoutY="360.0" mnemonicParsing="false" onAction="#backToDashboardButtonOA" text="Back to Dashboard" />
   </children>
</AnchorPane>
